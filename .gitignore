# =====================================================================
# Build artifacts
# =====================================================================

# Compiled binaries
simulator
simdebug

# Object files and dependency files
*.o
*.Po
*.Tpo
.deps/
.libs/

# =====================================================================
# Autotools-generated files (regenerated by aclocal/automake/autoconf/configure)
# =====================================================================
autom4te.cache/
Makefile
config.log
config.status
config.h
config.h.in
compile
depcomp
install-sh
missing
INSTALL
stamp-h1

# Note: Makefile.am, Makefile.in, configure, configure.ac, aclocal.m4
# ARE checked in and should not be ignored.

# =====================================================================
# Simulation output (regenerable)
# =====================================================================
output/
*.log
*.csv
*.png
*.pdf

# =====================================================================
# Editor / IDE
# =====================================================================
*.swp
*.swo
*~
.vscode/
.idea/
.DS_Store
Thumbs.db

# =====================================================================
# Python (if you add analysis scripts)
# =====================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ipynb_checkpoints/

# =====================================================================
# Docker (optional — keep image build cache out)
# =====================================================================
.dockerignore
